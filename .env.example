# ─── Nebius AI Cloud ─────────────────────────────────────────────────────────
# On a Nebius VM: auth is automatic via the service account attached to the VM.
# No API key needed — IAM token is fetched from the instance metadata service.
#
# For local development only — set this if running outside a Nebius VM:
# NEBIUS_API_KEY=your_nebius_api_key_here

NEBIUS_BASE_URL=https://api.studio.nebius.com/v1

# ─── Nebius Project (for Jobs API) ───────────────────────────────────────────
NEBIUS_PROJECT_ID=your_project_id_here
NEBIUS_FOLDER_ID=your_folder_id_here

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///data/benchmark_results.db

# ─── Benchmark Defaults ───────────────────────────────────────────────────────
DEFAULT_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct-fast
DEFAULT_CONCURRENCY=10
DEFAULT_REQUEST_COUNT=100
DEFAULT_MAX_TOKENS=256
DEFAULT_TIMEOUT_SECONDS=120

# ─── Streamlit ────────────────────────────────────────────────────────────────
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=true

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
